{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "noEmit": false,
    "declaration": true,
    "emitDeclarationOnly": true,
    "rootDir": "./src",
    "declarationDir": "./lib",
    "outDir": "./lib",
    "stripInternal": true
  },
  "include": [
    "src/env.d.ts",
    "src/index.ts",
    "src/components/**/*.ts",
    "src/components/**/*.vue",
    "src/masonry/**/*.ts"
  ],
  "exclude": ["tests/**"]
}
